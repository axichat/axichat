  <id>im.axi.axichat</id>
  <name>Axichat</name>
  <summary>Open-source XMPP and email client with calendar</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>AGPL-3.0-or-later</project_license>
